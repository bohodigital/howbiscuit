      ],
      "articleType": "guide",
      "editorialClassification": "guide",
      "articleFormat": "standard",
      "answerSummary": "Baking powder combines a dry acid and base that release carbon dioxide after liquid is added; heat expands those bubbles while the batter or dough sets around them.",
      "problemLabel": "My baking powder is not working",
