      "presentationBlocks": [
        {
          "id": "rise-mechanism",
          "kind": "mechanism",
          "steps": [
            {
              "title": "Liquid starts the reaction",
              "body": "Water lets the dry acid and base dissolve and meet. Their reaction releases carbon dioxide into the batter or dough."
            },
            {
              "title": "Bubbles get trapped",
              "body": "The gas fills existing air pockets in the mixture. Mixing method and batter structure decide how well those pockets hold."
            },
            {
              "title": "Heat expands, then sets",
              "body": "In the oven, gas expands and double-acting powder releases another round. Proteins and starches then set the final structure."
            }
          ]
        },
        {
          "id": "more-is-not-more",
          "kind": "callout",
          "variant": "dont-be-fooled",
          "title": "More baking powder does not mean more height",
          "body": "Too much can make a bake rise quickly and then collapse before the structure is strong enough to hold it. It can also leave an unpleasant chemical or bitter taste. Measure the recipe amount; the can is not a volume knob."
        },
        {
          "id": "failure-grid",
          "kind": "mistake-grid",
          "items": [
            {
              "title": "The can is tired",
              "body": "Moisture and time reduce its useful activity.",
              "fix": "Test a teaspoon in one-third cup of hot water. Vigorous foaming means it still has rising power."
            },
            {
              "title": "The batter waited",
              "body": "The first gas release began at mixing, then escaped while the bowl sat.",
              "fix": "Preheat the oven and prepare the pan before adding the wet ingredients."
            },
            {
              "title": "The amount drifted",
              "body": "A heaped spoon or a confused substitution changed the acid-base balance.",
              "fix": "Use a level measuring spoon and keep baking soda substitutions recipe-specific."
            },
            {
              "title": "The bubbles got bullied",
              "body": "Aggressive mixing can damage the structure that needs to hold expanding gas.",
              "fix": "For tender quick breads and biscuits, mix only until the dry streaks disappear."
            }
          ]
        },
        {
          "id": "cheap-safe-version",
          "kind": "callout",
          "variant": "cheap-safe",
          "title": "The cheap safe version",
          "body": "Test the can before buying another one. If it fails, replace it rather than improvising a large amount of baking soda. A small can costs less than a pan of dense, metallic-tasting cake."
        }
      ],
