---
import EmptyState from './EmptyState.astro';
import ProductCard from './ProductCard.astro';

interface Product {
  id: string; displayName: string; exactVariant: string; description: string; provenanceLabel: string;
  destination?: { relationship: 'unpaid'; merchant: string; exactUrl: string; capturedDate: string };
  price?: { renderedText: string; observedDate: string };
}
interface Props { title: string; purpose: string; review: string; products: Product[] }
const { title, purpose, review, products } = Astro.props;
const shelfId = `product-shelf-${title.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/(^-|-$)/g, '') || 'products'}`;
---
<section class="hb-product-shelf" aria-labelledby={shelfId}>
  <h3 id={shelfId}>{title}</h3>
  <p>{purpose}</p>
  <p><small>Review: {review}</small></p>
  {products.length > 0 ? <div class="hb-guide-grid">{products.map((product) => <ProductCard {product} />)}</div> : <EmptyState title="No verified products" message="No evidence-backed product records are available for this group." />}
</section>
