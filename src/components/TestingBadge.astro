---
interface Props { state: string; label?: string }
const { state, label } = Astro.props;
const labels: Record<string, string> = {
  'hands-on-tested': 'Hands-on tested',
  'owner-experience': 'Owner experience',
  'not-hands-on-tested': 'Not hands-on tested',
  'not-applicable': 'Testing not applicable',
  unavailable: 'Testing status unavailable',
};
const normalizedState = Object.hasOwn(labels, state) ? state : 'unavailable';
const text = label ?? labels[normalizedState];
---
<span class="hb-badge hb-testing-badge" data-state={normalizedState}>{text}</span>
