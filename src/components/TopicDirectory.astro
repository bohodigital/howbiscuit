---
import { homeTechTopics } from '../data/site-taxonomy.mjs';

const { current = '' } = Astro.props as { current?: string };
---

<div class="hb-topic-directory">
  {homeTechTopics.map((topic) => (
    <a href={topic.href} aria-current={current === topic.slug ? 'page' : undefined}>
      <h3>{topic.label}</h3>
      <p>{topic.description}</p>
      <span>{current === topic.slug ? 'Current section' : 'Open section'} →</span>
    </a>
  ))}
</div>
