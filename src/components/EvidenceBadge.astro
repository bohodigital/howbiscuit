---
const allowed = new Set([
  'Hands-on tested',
  'Owner experience',
  'Specification reviewed',
  'Researched',
  'Price listing only',
  'Editorial standard',
]);
const { value, label } = Astro.props as { value?: string | null; label?: string };
const text = value && allowed.has(value) ? value : 'Evidence unavailable';
const evidenceState = text.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/^-|-$/g, '');
---

<span class="hb-badge hb-evidence hb-evidence-label" data-evidence={evidenceState}>{label ?? text}</span>
