---
const { number, symbol, title, href, description, accent = 'honey' } = Astro.props as {
  number: string;
  symbol: string;
  title: string;
  href: string;
  description: string;
  accent?: string;
};
---

<a class="hb-topic-card" data-accent={accent} href={href}>
  <span class="hb-topic-number">{number}</span>
  <span class="hb-topic-symbol" aria-hidden="true">{symbol}</span>
  <h3>{title}</h3>
  <p>{description}</p>
  <span class="hb-card-link">Open guide <b>↗</b></span>
</a>
