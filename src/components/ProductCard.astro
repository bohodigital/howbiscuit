---
import PriceStatusBadge from './PriceStatusBadge.astro';
import { assertValidProductEvidence } from '../lib/public-content/model.mjs';
interface ProductCore {
  name: string;
  description: string;
  href?: string;
}
type Product = ProductCore & (
  | { priceState: 'observed' | 'stale'; price: string; observedAt: string; source: string }
  | { priceState: 'estimate'; price: string; observedAt?: never; source: string }
  | { priceState: 'unavailable'; price?: never; observedAt?: never; source?: string }
);
interface Props { product: Product }
const { product } = Astro.props;
assertValidProductEvidence(product);
---
<article class="hb-product-card">
  <h3>{product.href ? <a href={product.href}>{product.name}</a> : product.name}</h3>
  <p>{product.description}</p>
  <div>
    {product.price && <strong>{product.price}</strong>}
    {product.priceState === 'observed' || product.priceState === 'stale'
      ? <PriceStatusBadge state={product.priceState} observedAt={product.observedAt} />
      : <PriceStatusBadge state={product.priceState} />}
  </div>
  {product.source && <small>Source: {product.source}</small>}
</article>
