---
import PriceStatusBadge from './PriceStatusBadge.astro';
import { assertValidProductEvidence } from '../lib/public-content/model.mjs';

interface Product {
  id: string;
  displayName: string;
  exactVariant: string;
  description: string;
  provenanceLabel: string;
  destination?: { relationship: 'unpaid'; merchant: string; exactUrl: string; capturedDate: string };
  price?: { renderedText: string; observedDate: string };
}
interface Props { product: Product }
const { product } = Astro.props;
assertValidProductEvidence(product);
---
<article class="hb-product-card">
  <h3>{product.displayName}</h3>
  <p><strong>Exact variant:</strong> {product.exactVariant}</p>
  <p>{product.description}</p>
  <p><small>{product.provenanceLabel}</small></p>
  {product.price && <><p>{product.price.renderedText}</p><PriceStatusBadge observedAt={product.price.observedDate} /></>}
  {product.destination
    ? <p><a href={product.destination.exactUrl}>View the unpaid {product.destination.merchant} listing</a> <small>(captured {product.destination.capturedDate}; How Biscuit receives no compensation)</small></p>
    : <p><small>No verified shopping destination is available.</small></p>}
</article>
