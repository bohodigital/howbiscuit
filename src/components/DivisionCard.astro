---
const { title, href, description, accent = 'honey' } = Astro.props as {
  title: string;
  href: string;
  description: string;
  accent?: string;
};
---

<a class="hb-card hb-division-card" data-accent={accent} href={href}>
  <span class="hb-card-title">{title}</span>
  <span>{description}</span>
</a>
