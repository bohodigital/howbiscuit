---
type Variant = 'short-answer' | 'common-mistake' | 'cheap-safe' | 'dont-be-fooled' | 'source-note';

const labels: Record<Variant, string> = {
  'short-answer': 'Short answer',
  'common-mistake': 'Common mistake',
  'cheap-safe': 'Cheap safe version',
  'dont-be-fooled': "Don't be fooled",
  'source-note': 'Source note',
};

const { variant = 'short-answer', title } = Astro.props as {
  variant?: Variant;
  title?: string;
};
const accessibleName = title ?? labels[variant];
---

<aside class="hb-box" data-variant={variant} aria-label={accessibleName}>
  <p class="hb-box-label">{accessibleName}</p>
  <slot />
</aside>
