---
const { sources } = Astro.props as { sources: Array<{ title: string; publisher: string; href: string }> };
---

<section class="hb-sources" aria-labelledby="source-notes">
  <div><span>Sources reviewed</span><h2 id="source-notes">Source notes</h2></div>
  <ol>
    {sources.map((source) => <li><a href={source.href}>{source.title}</a><span>{source.publisher}</span></li>)}
  </ol>
</section>
