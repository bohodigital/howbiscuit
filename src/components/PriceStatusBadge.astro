---
import { assertValidPriceBadgeProps } from '../lib/public-content/model.mjs';

interface Props { observedAt: string }
const { observedAt } = Astro.props;
assertValidPriceBadgeProps({ observedAt });
---
<span class="hb-badge hb-price-status" data-state="observed">Price observed as of {observedAt}</span>
