---
import Default from '@astrojs/starlight/components/PageTitle.astro';
const data = Astro.locals.starlightRoute.entry.data as typeof Astro.locals.starlightRoute.entry.data & {
  division?: string;
  evidence?: string;
  readTime?: string;
  updatedDate?: string | Date;
};
const division = data.division ?? '';
const isArticle = data.kind === 'article';
const isDivision = data.kind === 'division';
const labels: Record<string, string> = {
  cook: 'Cooking',
  'research-writing': 'Research & Writing',
  math: 'Math',
  'home-tech': 'Home Tech',
  'make-do': 'Home & DIY',
  science: 'Science',
};
---

{isArticle ? (
  <header class="hb-article-title">
    <a class="hb-back-link" href="/articles/">← All articles</a>
    <div class="hb-article-labels">
      <span class="hb-topic-label">{labels[division] ?? 'Guide'}</span>
      <span class="hb-evidence-label">{data.evidence ?? 'Researched'}</span>
    </div>
    <h1 id="_top">{data.title}</h1>
    <p>{data.description}</p>
    <div class="hb-article-meta">
      <span>How Biscuit guide</span>
      <span>Updated {data.updatedDate ?? data.lastUpdated}</span>
      <span>{data.readTime ?? '6 min read'}</span>
    </div>
  </header>
) : isDivision ? (
  <header class="hb-hub-title" data-division={division || 'articles'}>
    <span>{labels[division] ?? 'How Biscuit'} section</span>
    <h1 id="_top">{data.title}</h1>
    <p>{data.description}</p>
  </header>
) : (
  <Default><slot /></Default>
)}
