---
import { getPublicSiteData } from '../lib/public-content/site-registry.mjs';

interface Props { currentPath?: string }
interface NavigationTopic { id: string; label: string; mode: 'filter' | 'standalone'; count: number; href: string }
interface NavigationGuide { href: string; title: string; description: string; topicId: string | null }
interface NavigationCategory {
  id: string;
  label: string;
  description: string;
  href: string;
  topicLabels: readonly NavigationTopic[];
  guideLinks: readonly NavigationGuide[];
}
interface NavigationModel {
  categories: readonly NavigationCategory[];
  allGuides: { label: string; href: string };
}
const { currentPath = '/' } = Astro.props;
const { navigation } = getPublicSiteData() as { navigation: NavigationModel };
---

<header class="hb-custom-header" data-pagefind-ignore="all">
  <div class="hb-header-inner">
    <a class="hb-brand" href="/" aria-label="How Biscuit home" aria-current={currentPath === '/' ? 'page' : undefined}>
      <span>HOW BISCUIT</span><b aria-hidden="true">?</b><i>Practical guides</i>
    </a>

    <nav class="hb-desktop-nav" aria-label="Primary navigation">
      {navigation.categories.map((category) => (
        <details class="hb-category-menu" name="hb-primary-navigation" data-category={category.id}>
          <summary>{category.label}<span aria-hidden="true"></span></summary>
          <div class="hb-category-panel">
            <div class="hb-category-intro"><a href={category.href}><strong>{category.label}</strong><span>Open category →</span></a><p>{category.description}</p></div>
            {category.topicLabels.length > 0 && (
              <div class="hb-topic-labels" aria-label={`${category.label} published topics`}>
                {category.topicLabels.map((topic) => <a href={topic.href}>{topic.label}<span>{topic.count}</span></a>)}
              </div>
            )}
            {category.guideLinks.length > 0 && (
              <div class="hb-menu-guides">
                {category.guideLinks.map((guide) => (
                  <a href={guide.href}><strong>{guide.title}</strong><small>{guide.description}</small></a>
                ))}
              </div>
            )}
          </div>
        </details>
      ))}
      <a class="hb-all-guides-link" href={navigation.allGuides.href} aria-current={currentPath === '/articles/' ? 'page' : undefined}>{navigation.allGuides.label}</a>
      <button class="hb-header-action" id="search-trigger" type="button" data-open-modal="search" aria-haspopup="dialog">Search</button>
      <button class="hb-header-action hb-theme-control" type="button" data-theme-control aria-label="Theme: System. Activate for Light.">Theme: System</button>
    </nav>

    <div class="hb-mobile-actions">
      <button class="hb-header-action" id="mobile-navigation-trigger" type="button" data-open-modal="mobile-navigation" aria-haspopup="dialog">Menu</button>
      <button class="hb-header-action" id="mobile-search-trigger" type="button" data-open-modal="search" aria-haspopup="dialog">Search</button>
      <button class="hb-header-action hb-theme-control" type="button" data-theme-control aria-label="Theme: System. Activate for Light.">Theme</button>
    </div>
  </div>
</header>

<noscript>
  <details class="hb-noscript-navigation">
    <summary>Browse How Biscuit</summary>
    <nav aria-label="Primary navigation without JavaScript">
      {navigation.categories.map((category) => (
        <div>
          <a href={category.href}><strong>{category.label}</strong></a>
          {category.guideLinks.map((guide) => <a href={guide.href}>{guide.title}</a>)}
        </div>
      ))}
      <a class="hb-mobile-all-guides" href={navigation.allGuides.href}>{navigation.allGuides.label}</a>
    </nav>
  </details>
</noscript>

<dialog class="hb-shell-dialog hb-mobile-navigation-dialog" id="mobile-navigation-dialog" aria-labelledby="mobile-navigation-title">
  <div class="hb-dialog-card">
    <header><h2 id="mobile-navigation-title">Explore How Biscuit</h2><button type="button" data-close-modal aria-label="Close menu">Close</button></header>
    <nav aria-label="Mobile navigation">
      {navigation.categories.map((category) => (
        <details class="hb-mobile-category">
          <summary>{category.label}<span aria-hidden="true">+</span></summary>
          <div>
            <a class="hb-mobile-category-link" href={category.href}>Open {category.label} →</a>
            <p>{category.description}</p>
            {category.topicLabels.length > 0 && <p class="hb-mobile-topic-labels">{category.topicLabels.map((topic) => <a href={topic.href}>{topic.label}</a>)}</p>}
            {category.guideLinks.map((guide) => <a href={guide.href}>{guide.title}</a>)}
          </div>
        </details>
      ))}
      <a class="hb-mobile-all-guides" href={navigation.allGuides.href}>{navigation.allGuides.label}</a>
    </nav>
  </div>
</dialog>

<dialog class="hb-shell-dialog hb-search-dialog" id="search-dialog" aria-labelledby="search-dialog-title">
  <div class="hb-dialog-card">
    <header><h2 id="search-dialog-title">Search How Biscuit</h2><button type="button" data-close-modal aria-label="Close search">Close</button></header>
    <form class="hb-search-form" role="search">
      <label for="howbiscuit-search-input">Search published guides and pages</label>
      <div><input id="howbiscuit-search-input" type="search" name="q" autocomplete="off" spellcheck="false" /><button type="submit">Search</button></div>
    </form>
    <p class="hb-search-status" role="status" aria-live="polite">Enter a word or phrase to search.</p>
    <div class="hb-search-results" aria-label="Search results"></div>
  </div>
</dialog>

<style>
  .hb-category-intro a {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
    color: var(--hb-ink);
    text-decoration: none;
  }
  .hb-category-intro a > span {
    color: var(--hb-tomato-text);
    font-size: 0.68rem;
    font-weight: 850;
  }
  .hb-topic-labels a,
  .hb-mobile-topic-labels a {
    border: 1px solid var(--hb-ink);
    border-radius: 999px;
    padding: 0.3rem 0.5rem;
    background: var(--hb-paper-deep);
    color: var(--hb-ink);
    font-size: 0.66rem;
    font-weight: 800;
    text-decoration: none;
  }
  .hb-topic-labels a > span { margin-left: 0.3rem; }
  .hb-mobile-category-link {
    display: inline-block;
    margin-bottom: 0.7rem;
    color: var(--hb-ink);
    font-weight: 850;
  }
</style>

<script>
  import { createInitialModalState, modalFocusReturnCandidates, reduceModalState } from '../lib/public-content/modal-coordinator.mjs';

  const dialogs = new Map([
    ['mobile-navigation', document.querySelector<HTMLDialogElement>('#mobile-navigation-dialog')],
    ['search', document.querySelector<HTMLDialogElement>('#search-dialog')],
  ]);
  interface ModalViewState {
    openModalId: 'mobile-navigation' | 'search' | null;
    returnFocusId: string | null;
    focusTargetId?: string | null;
    closeReason?: string;
  }
  let modalState = createInitialModalState() as ModalViewState;
  const desktopNavigationMedia = matchMedia('(min-width: 75.01rem)');

  function openModal(modalId: 'mobile-navigation' | 'search', trigger: HTMLElement) {
    const current = modalState.openModalId ? dialogs.get(modalState.openModalId) : null;
    if (current?.open) current.close();
    modalState = reduceModalState(modalState, {
      type: 'open',
      modalId,
      returnFocusId: trigger.id,
    });
    const dialog = dialogs.get(modalId);
    if (!dialog) return;
    dialog.showModal();
    document.body.classList.add('hb-modal-open');
    const focusTarget = modalId === 'search'
      ? dialog.querySelector<HTMLInputElement>('input[type="search"]')
      : dialog.querySelector<HTMLElement>('summary, a, button');
    window.requestAnimationFrame(() => focusTarget?.focus());
  }

  function closeModal(reason: 'button' | 'escape' | 'outside' | 'replacement' | 'result', returnFocus = true) {
    if (!modalState.openModalId) return;
    const dialog = dialogs.get(modalState.openModalId);
    modalState = reduceModalState(modalState, { type: 'close', reason });
    if (dialog?.open) dialog.close();
    document.body.classList.remove('hb-modal-open');
    let focusTarget: HTMLElement | null = null;
    if (returnFocus && modalState.focusTargetId) {
      for (const candidateId of modalFocusReturnCandidates(modalState.focusTargetId)) {
        const candidate = document.getElementById(candidateId);
        if (candidate && candidate.getClientRects().length > 0) {
          focusTarget = candidate;
          break;
        }
      }
    }
    if (focusTarget) window.requestAnimationFrame(() => focusTarget.focus());
  }

  document.querySelectorAll<HTMLElement>('[data-open-modal]').forEach((trigger) => {
    trigger.addEventListener('click', () => openModal(trigger.dataset.openModal as 'mobile-navigation' | 'search', trigger));
  });
  document.querySelectorAll<HTMLElement>('[data-close-modal]').forEach((button) => button.addEventListener('click', () => closeModal('button')));
  dialogs.forEach((dialog) => {
    dialog?.addEventListener('cancel', (event) => { event.preventDefault(); closeModal('escape'); });
    dialog?.addEventListener('pointerdown', (event) => { if (event.target === dialog) closeModal('outside'); });
    dialog?.querySelectorAll('a').forEach((link) => link.addEventListener('click', () => closeModal('result')));
  });

  desktopNavigationMedia.addEventListener('change', ({ matches }) => {
    if (matches && modalState.openModalId === 'mobile-navigation') closeModal('replacement', false);
  });

  const categoryMenus = Array.from(document.querySelectorAll<HTMLDetailsElement>('.hb-category-menu'));
  const closeCategoryMenus = (except?: HTMLDetailsElement) => categoryMenus.forEach((menu) => { if (menu !== except) menu.open = false; });
  categoryMenus.forEach((menu) => {
    let closeTimer = 0;
    const cancelClose = () => window.clearTimeout(closeTimer);
    const scheduleClose = () => {
      cancelClose();
      closeTimer = window.setTimeout(() => { if (!menu.contains(document.activeElement)) menu.open = false; }, 180);
    };
    menu.addEventListener('toggle', () => { if (menu.open) closeCategoryMenus(menu); });
    menu.addEventListener('mouseenter', () => { cancelClose(); closeCategoryMenus(menu); menu.open = true; });
    menu.addEventListener('mouseleave', scheduleClose);
    menu.addEventListener('focusin', cancelClose);
    menu.addEventListener('focusout', () => window.requestAnimationFrame(() => { if (!menu.contains(document.activeElement)) menu.open = false; }));
  });
  document.addEventListener('pointerdown', (event) => {
    const target = event.target;
    if (!(target instanceof Node) || !categoryMenus.some((menu) => menu.contains(target))) closeCategoryMenus();
  });
  document.addEventListener('keydown', (event) => {
    if (event.key !== 'Escape') return;
    if (modalState.openModalId) {
      event.preventDefault();
      closeModal('escape');
      return;
    }
    const menu = categoryMenus.find(({ open }) => open);
    if (!menu) return;
    menu.open = false;
    menu.querySelector<HTMLElement>('summary')?.focus();
  });

  const themePreferences = ['system', 'light', 'dark'] as const;
  const media = matchMedia('(prefers-color-scheme: dark)');
  function applyTheme(preference: typeof themePreferences[number]) {
    const resolved = preference === 'system' ? (media.matches ? 'dark' : 'light') : preference;
    document.documentElement.dataset.themePreference = preference;
    document.documentElement.dataset.theme = resolved;
    document.querySelectorAll<HTMLButtonElement>('[data-theme-control]').forEach((button) => {
      const next = themePreferences[(themePreferences.indexOf(preference) + 1) % themePreferences.length];
      const label = preference[0].toUpperCase() + preference.slice(1);
      const nextLabel = next[0].toUpperCase() + next.slice(1);
      button.textContent = button.closest('.hb-mobile-actions') ? 'Theme' : `Theme: ${label}`;
      button.setAttribute('aria-label', `Theme: ${label}. Activate for ${nextLabel}.`);
    });
  }
  let storedTheme: string | null = null;
  try { storedTheme = localStorage.getItem('howbiscuit-theme'); } catch { storedTheme = null; }
  applyTheme(themePreferences.includes(storedTheme as typeof themePreferences[number]) ? storedTheme as typeof themePreferences[number] : 'system');
  document.querySelectorAll<HTMLButtonElement>('[data-theme-control]').forEach((button) => button.addEventListener('click', () => {
    const current = document.documentElement.dataset.themePreference as typeof themePreferences[number];
    const next = themePreferences[(themePreferences.indexOf(current) + 1) % themePreferences.length];
    try { localStorage.setItem('howbiscuit-theme', next); } catch { /* Preference remains active for this page. */ }
    applyTheme(next);
  }));
  media.addEventListener('change', () => { if (document.documentElement.dataset.themePreference === 'system') applyTheme('system'); });

  const searchForm = document.querySelector<HTMLFormElement>('.hb-search-form');
  const searchInput = document.querySelector<HTMLInputElement>('#howbiscuit-search-input');
  const searchStatus = document.querySelector<HTMLElement>('.hb-search-status');
  const searchResults = document.querySelector<HTMLElement>('.hb-search-results');
  let searchSequence = 0;
  function setSearchStatus(message: string) { if (searchStatus) searchStatus.textContent = message; }
  function textFromHtml(value: string) {
    const template = document.createElement('template');
    template.innerHTML = value;
    return template.content.textContent?.trim() ?? '';
  }
  async function runSearch(query: string) {
    const sequence = ++searchSequence;
    if (!searchResults) return;
    searchResults.replaceChildren();
    if (!query.trim()) { setSearchStatus('Enter a word or phrase to search.'); return; }
    setSearchStatus('Searching…');
    try {
      const pagefindPath = '/pagefind/pagefind.js';
      const pagefind = await import(/* @vite-ignore */ pagefindPath);
      const response = await pagefind.search(query.trim());
      if (sequence !== searchSequence) return;
      if (response.results.length === 0) { setSearchStatus(`No results found for “${query.trim()}”.`); return; }
      const records = await Promise.all(response.results.slice(0, 12).map((result: { data: () => Promise<any> }) => result.data()));
      if (sequence !== searchSequence) return;
      const fragment = document.createDocumentFragment();
      records.forEach((record) => {
        const article = document.createElement('article');
        article.className = 'hb-search-result-card';
        const title = document.createElement('h3');
        const link = document.createElement('a');
        link.href = record.url;
        link.textContent = record.meta?.title || record.url;
        link.addEventListener('click', () => closeModal('result'));
        title.append(link);
        const description = document.createElement('p');
        description.textContent = record.meta?.description || textFromHtml(record.excerpt || '');
        const meta = document.createElement('span');
        const filters = record.filters || {};
        meta.textContent = [filters.category, filters.type, record.url].flat().filter(Boolean).join(' · ');
        article.append(title, description, meta);
        fragment.append(article);
      });
      searchResults.append(fragment);
      setSearchStatus(`${records.length} result${records.length === 1 ? '' : 's'} found.`);
    } catch (error) {
      if (sequence !== searchSequence) return;
      console.error('How Biscuit search failed', error);
      setSearchStatus('Search is temporarily unavailable. Try again later or browse All Guides.');
    }
  }
  searchForm?.addEventListener('submit', (event) => { event.preventDefault(); void runSearch(searchInput?.value ?? ''); });
</script>
