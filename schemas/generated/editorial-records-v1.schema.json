            "first-party",
            "editorial-policy"
          ]
        },
        "authorityNotes": {
          "type": "string",
          "minLength": 1
        },
        "archiveNotes": {
          "default": [],
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "rightsRestrictions": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "type": "string",
          "enum": [
            "draft",
            "active",
            "retired",
            "disallowed"
          ]
        }
