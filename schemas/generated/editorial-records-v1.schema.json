        "id",
        "title",
        "publisher",
        "author",
        "canonicalUrl",
        "publicationIdentity",
        "publicationDate",
        "accessedDate",
        "sourceType",
        "authorityNotes",
        "rightsRestrictions",
        "status"
      ],
