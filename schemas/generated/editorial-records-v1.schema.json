{
  "schemaVersion": "1.0.0",
  "records": {
    "idea": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "type": "object",
      "properties": {
        "schemaVersion": {
          "type": "string",
          "const": "1.0.0"
        },
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "proposedCategory": {
          "anyOf": [
            {
              "type": "string",
              "enum": [
                "home-tech",
                "home",
                "kitchen",
                "shop",
                "tools"
              ]
            },
            {
              "type": "null"
            }
          ]
        },
        "proposedTopics": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "wifi-routers",
              "computers-laptops",
              "smart-home",
              "tvs-streaming",
              "privacy-security",
              "power-cooling-storage",
              "repairs-maintenance",
              "apartment-comfort",
              "heating-cooling",
              "cleaning",
              "tools-materials",
              "utilities-energy",
              "kitchen-appliances",
              "cookware-tools",
              "food-science",
              "ingredient-substitutions",
              "cheap-meals",
              "troubleshooting-safety",
              "product-comparisons",
              "local-prices",
              "used-refurbished",
              "total-cost-ownership",
              "deals-worth-considering",
              "products-to-avoid",
              "product-index",
              "calculators",
              "converters",
              "price-checkers",
              "checklists",
              "decision-tools",
              "templates"
            ]
          }
        },
        "userProblem": {
          "type": "string",
          "minLength": 1
        },
        "intendedAudience": {
          "type": "string",
          "minLength": 1
        },
        "durability": {
          "type": "string",
          "minLength": 1
        },
        "productRelevance": {
          "type": "string",
          "minLength": 1
        },
        "evidenceFeasibility": {
          "type": "string",
          "minLength": 1
        },
        "competitionOpportunity": {
          "type": "string",
          "minLength": 1
        },
        "productionEffort": {
          "type": "string",
          "minLength": 1
        },
        "risk": {
          "type": "string",
          "minLength": 1
        },
        "scoreComponents": {
          "type": "object",
          "properties": {
            "durability": {
              "type": "integer",
              "minimum": 1,
              "maximum": 5
            },
            "productRelevance": {
              "type": "integer",
              "minimum": 1,
              "maximum": 5
            },
            "evidenceFeasibility": {
              "type": "integer",
              "minimum": 1,
              "maximum": 5
            },
            "opportunity": {
              "type": "integer",
              "minimum": 1,
              "maximum": 5
            },
            "productionEffort": {
              "type": "integer",
              "minimum": 1,
              "maximum": 5
            },
            "risk": {
              "type": "integer",
              "minimum": 1,
              "maximum": 5
            }
          },
          "required": [
            "durability",
            "productRelevance",
            "evidenceFeasibility",
            "opportunity",
            "productionEffort",
            "risk"
          ],
          "additionalProperties": false
        },
        "totalScore": {
          "type": "integer",
          "minimum": -9007199254740991,
          "maximum": 9007199254740991
        },
        "status": {
          "type": "string",
          "enum": [
            "candidate",
            "selected",
            "briefed",
            "published",
            "retired"
          ]
        },
        "notes": {
          "default": [],
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      },
      "required": [
        "schemaVersion",
        "id",
        "title",
        "proposedCategory",
        "proposedTopics",
        "userProblem",
        "intendedAudience",
        "durability",
        "productRelevance",
        "evidenceFeasibility",
        "competitionOpportunity",
        "productionEffort",
        "risk",
        "scoreComponents",
        "totalScore",
        "status"
      ],
      "additionalProperties": false
    },
