        },
        "requiredSourceTypes": {
          "default": [],
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "candidateSourceIds": {
          "default": [],
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
          }
        },
        "testingNeeds": {
          "default": [],
          "type": "array",
          "items": {
            "type": "string",
