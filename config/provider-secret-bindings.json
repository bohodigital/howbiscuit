{
  "schemaVersion": "1.0.0",
  "brokerReference": "local1.public-data-provider-credentials.primary",
  "providers": {
    "eia": {
      "fieldId": "eia_api_key",
      "runtimeBinding": "HOWBISCUIT_EIA_API_KEY",
      "owningService": "howbiscuit-provider-refresh"
    },
    "hud-usps": {
      "fieldId": "hud_api_key",
      "runtimeBinding": "HOWBISCUIT_HUD_USPS_ACCESS_TOKEN",
      "owningService": "howbiscuit-provider-refresh"
    },
    "best-buy": {
      "fieldId": "bestbuy_api_key",
      "runtimeBinding": "HOWBISCUIT_BESTBUY_API_KEY",
      "owningService": "howbiscuit-provider-refresh"
    },
    "kroger-client-id": {
      "fieldId": "kroger_oauth_client_id",
      "runtimeBinding": "HOWBISCUIT_KROGER_CLIENT_ID",
      "owningService": "howbiscuit-provider-refresh"
    },
    "kroger-client-secret": {
      "fieldId": "kroger_oauth_client_secret",
      "runtimeBinding": "HOWBISCUIT_KROGER_CLIENT_SECRET",
      "owningService": "howbiscuit-provider-refresh"
